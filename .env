# FerrePro — Environment Variables
# Copy this file to .env and fill in your values

# Supabase database connection URL (required)
# Get this from your Supabase Project -> Settings -> Database -> Connection string
SUPABASE_DATABASE_URL=postgresql://postgres.wzsgatonbfpaycpjerjv:zLn1SGUaXyG6VMHB@aws-1-us-west-2.pooler.supabase.com:5432/postgres

# Supabase connection pool size. Use 1 if you hit max clients in session mode.
SUPABASE_POOL_MIN_SIZE=1
SUPABASE_POOL_MAX_SIZE=1

# Admin password for the app (optional, default: ferrepro2026)
ADMIN_PASS=ferrepro2026

# Flask port (optional, default: 5000)
PORT=5000